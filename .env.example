# ============================================================
# consultant-kr Hook 환경변수 템플릿
# ============================================================
# 사용법:
#   cp .env.example .env
#   vi .env   # 실제 값 입력
#   source .env   # 또는 direnv 사용
# ============================================================

# ---------- 카카오워크 알림 ----------
# 카카오워크 관리자 페이지 > 봇 생성 > 웹훅 URL 발급
# 미설정 시 카카오워크 알림은 스킵됨
KAKAOWORK_WEBHOOK_URL=""

# ---------- Slack 알림 ----------
# Slack App > Incoming Webhooks > Add New Webhook to Workspace
# 미설정 시 Slack 알림은 스킵됨
SLACK_WEBHOOK_URL=""

# ---------- Velog 블로그 초안 자동 생성 ----------
# 1 = 활성화 (세션 종료 시 오늘 리포트를 블로그 초안으로 자동 변환)
# 0 = 비활성화 (기본값 — 과도한 Claude 호출 방지)
# 주의: 활성화 시 세션 종료마다 Claude Code 가 한 번 더 호출되어 토큰 소모
AUTO_BLOG_DRAFT=0

# ---------- 시간대 (서버가 UTC인 경우) ----------
# 국내 서버는 기본 KST이므로 불필요
# 해외 서버 사용 시만 설정
# TZ="Asia/Seoul"
